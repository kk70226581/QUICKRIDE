VITE_SERVER_URL = http://localhost:3000
VITE_ENVIRONMENT = development # Change to "production" for deployment
VITE_RIDE_TIMEOUT = 90000 # ride will automatically cancel after 1.5 minutes if no-one accepts the ride
VITE_GOOGLE_CLIENT_ID = <your-google-oauth-2.0-client-id>
VITE_ENABLE_GOOGLE_SIGNIN = true # Google OAuth client must allow the running frontend origin
VITE_GOOGLE_ALLOWED_ORIGINS = http://localhost:5173,http://127.0.0.1:5173
